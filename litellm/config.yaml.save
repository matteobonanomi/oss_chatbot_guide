model_list:

  - model_name: mistral_24b
    litellm_params:
      model: openrouter/mistralai/mistral-small-24b-instruct-2501
      api_key: os.environ/OPENROUTER_API_KEY
      extra_headers:
        HTTP-Referer: os.environ/OR_SITE_URL
        X-Title: os.environ/OR_APP_NAME

  - model_name: llama3.1_70b
    litellm_params:
      model: openrouter/meta-llama/llama-3.1-70b-instruct
      api_key: os.environ/OPENROUTER_API_KEY
      extra_headers:
        HTTP-Referer: os.environ/OR_SITE_URL
        X-Title: os.environ/OR_APP_NAME

  - model_name: gemma3_27b
    litellm_params:
      model: openrouter/google/gemma-3-27b-it
      api_key: os.environ/OPENROUTER_API_KEY
      extra_headers:
        HTTP-Referer: os.environ/OR_SITE_URL
        X-Title: os.environ/OR_APP_NAME

  - model_name: llama3.2_3b
    litellm_params:
      model: openrouter/meta-llama/llama-3.2-3b-instruct
      api_key: os.environ/OPENROUTER_API_KEY
      extra_headers:
        HTTP-Referer: os.environ/OR_SITE_URL
        X-Title: os.environ/OR_APP_NAME

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
  max_budget: 15
