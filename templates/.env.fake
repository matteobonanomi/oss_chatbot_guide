# =========================
# LibreChat
# =========================
PUBLIC_URL=your_url_is_here

CREDS_KEY=YOUR_KEY_IS_HERE
CREDS_IV=YOUR_KEY_IS_HERE
JWT_SECRET=YOUR_KEY_IS_HERE
JWT_REFRESH_SECRET=YOUR_KEY_IS_HERE

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

# opzionale per non rifare login spesso (valori in millisecondi)
SESSION_EXPIRY=43200000          # 12 ore
REFRESH_TOKEN_EXPIRY=2592000000  # 30 giorni

# =========================
# Cloudflare Tunnel
# =========================
CLOUDFLARE_TUNNEL_TOKEN=YOUR_KEY_IS_HERE

# =========================
# LiteLLM
# =========================
LITELLM_MASTER_KEY=sk-YOUR_KEY_IS_HERE

# =========================
# OpenRouter
# =========================
OPENROUTER_API_KEY=sk-OUR_KEY_IS_HERE
OR_SITE_URL=https://chat.mbprojects.uk
OR_APP_NAME=LibreChat

# =========================
# RAG API / pgvector
# =========================
RAG_API_URL=http://rag_api:8000
RAG_USE_FULL_CONTEXT=false

RAG_POSTGRES_DB=rag_api
RAG_POSTGRES_USER=rag
RAG_POSTGRES_PASSWORD=YOUR_KEY_IS_HERE

# Embeddings backend used by the RAG service.
# Using LiteLLM through an OpenAI-compatible API.
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=bge-m3
RAG_OPENAI_API_KEY=${LITELLM_MASTER_KEY}
RAG_OPENAI_BASEURL=http://litellm:4000/v1
OPENAI_API_KEY=${LITELLM_MASTER_KEY}
# Collection / index namespace inside the vector DB.
# Change this if you want isolated indexes per environment or tenant.
RAG_COLLECTION_NAME=librechat
# Approximate chunk size used when splitting documents before embedding.
# Larger chunks preserve more context; smaller chunks improve retrieval precision.
RAG_CHUNK_SIZE=1000
# Number of overlapping characters/tokens between adjacent chunks.
# Helps avoid losing context at chunk boundaries, but too much overlap increases index size.
RAG_CHUNK_OVERLAP=120
# Number of chunks embedded per batch during indexing.
# Higher = faster indexing, but more RAM/VRAM usage.
RAG_EMBEDDING_BATCH_SIZE=64
# Max number of embedding jobs queued at once.
# Lower values are safer; higher values can improve throughput but increase memory pressure.
RAG_EMBEDDING_MAX_QUEUE_SIZE=2
# Whether to extract images from PDFs during ingestion.
# Keep false for text-heavy PDFs; enable only if charts/figures are important.
PDF_EXTRACT_IMAGES=false
# Enable only when troubleshooting.
DEBUG_RAG_API=False
DEBUG_PGVECTOR_QUERIES=False

# ===================================
# --- LibreChat native web search ---
# ===================================

# SearXNG self-hosted -- generate a random secret
SEARXNG_INSTANCE_URL=http://searxng:8080
SEARXNG_SECRET=YOUR_KEY_IS_HERE

# Serper top-up / no monthly subscription
SERPER_API_KEY=YOUR_KEY_IS_HERE

# Jina reranker
JINA_API_KEY=jina_YOUR_KEY_IS_HERE